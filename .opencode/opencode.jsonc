{
    "$schema": "https://opencode.ai/config.json",
    "default_agent": "hubs",
    "formatter": true,
    "lsp": true,
    "instructions": [
        "AGENTS.md",
        "./rules/artifact-placement.md"
    ],
    "permission": {
        "edit": {
            ".opencode/**": "allow",
            "css/**": "allow",
            "JS/**": "allow",
            "resources/**": "allow",
            "utils/**": "allow",
            "userChrome.css": "allow",
            "userContent.css": "allow"
        },
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "skill": "allow",
        "todowrite": "allow",
        "question": "allow"
    }
}
